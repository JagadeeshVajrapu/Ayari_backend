{

  "compilerOptions": {

    "target": "ES2022",

    "module": "commonjs",

    "lib": ["ES2022"],

    "strict": true,

    "esModuleInterop": true,

    "skipLibCheck": true,

    "forceConsistentCasingInFileNames": true,

    "resolveJsonModule": true,

    "incremental": true,

    "noEmit": true,

    "typeRoots": ["./node_modules/@types", "./src/types"]

  },

  "include": ["src/**/*"],

  "exclude": ["node_modules", "dist"]

}

