# Server
NODE_ENV=development
PORT=5000

# PostgreSQL (Docker — see docker-compose.yml at repo root)
# Note: Docker maps host port 5433 → container 5432 (avoids local PostgreSQL conflicts on Windows)
DATABASE_URL="postgresql://postgres:admin123@localhost:5433/ayari?schema=public"

# Docker Postgres credentials (used by docker-compose.yml)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=admin123
POSTGRES_DB=ayari
POSTGRES_PORT=5433

# JWT
JWT_ACCESS_SECRET=your-super-secret-access-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_ACCESS_EXPIRES_IN=14d
JWT_REFRESH_EXPIRES_IN=90d

# Password Reset
PASSWORD_RESET_EXPIRES_IN=1h

# Frontend URL (for reset password links, CORS, and cookies)
# Production: must match the live storefront origin (no trailing slash)
FRONTEND_URL=http://localhost:3001
# Optional extra CORS origins (comma-separated), e.g. preview deploy URLs
# CORS_ORIGINS=https://www.ayaricreations.com,https://ayaricreations.com

# Cookie — set true in production (HTTPS). Enables SameSite=None for cross-domain API auth.
COOKIE_SECURE=false

# OTP expiry for email verification
OTP_EXPIRES_IN=10m

# Email / SMTP — leave blank to print codes in the backend terminal
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM="AYARI <noreply@ayari.com>"

# Razorpay — https://dashboard.razorpay.com/app/keys (use Test Mode for localhost)
# Leave keys empty OR set RAZORPAY_MOCK=true to simulate payment without the Razorpay modal
RAZORPAY_MOCK=true
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Webhook secret — optional for local; needed for production webhook callbacks
# RAZORPAY_WEBHOOK_SECRET=whsec_xxxxx

# Cloudinary — REQUIRED in production for product image uploads
# CLOUDINARY_CLOUD_NAME = the "Cloud name" badge in Cloudinary dashboard (e.g. zf3w0zec)
# NOT the API key display name (e.g. "Ayari Creations")
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Seed users (optional — used by `npm run prisma:seed`)
SEED_ADMIN_EMAIL=admin@ayari.com
SEED_ADMIN_PASSWORD=Admin@123456
SEED_CUSTOMER_EMAIL=customer@ayari.com
SEED_CUSTOMER_PASSWORD=Customer@123456



# Shiprocket (optional — leave blank to keep local/manual shipping only)
# https://app.shiprocket.in → API User credentials
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=
# Optional cached token (auto-refreshed via login when empty/expired)
# SHIPROCKET_TOKEN=
SHIPROCKET_API=https://apiv2.shiprocket.in/v1/external
# Pickup location name configured in Shiprocket dashboard
SHIPROCKET_PICKUP_LOCATION=Primary
# Optional webhook shared secret
# SHIPROCKET_WEBHOOK_SECRET=
